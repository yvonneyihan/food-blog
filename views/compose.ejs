<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Compose</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/styles/styles.css" />
  <link href="https://fonts.googleapis.com/css2?family=Ga+Maamli&family=Oswald:wght@200..700&display=swap" rel="stylesheet" />

  <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet" />


</head>

<body>
  <%- include("header.ejs") %>

  <div class="container my-5">
    <div class="row justify-content-center">
      <div class="col-lg-9">
        <div class="compose-card">
          <h1 class="compose-heading mb-4">Compose a New Post</h1>

          <form id="composeForm" action="/posts/compose" method="POST" enctype="multipart/form-data" class="compose-form">
            
            <div class="mb-4">
              <label for="title" class="form-label">Title</label>
              <input type="text" id="title" name="title" class="form-control compose-input" required />
            </div>

            <div class="mb-4">
              <label for="category" class="form-label">Category</label>
              <select name="category" id="category" class="form-select compose-select" required>
                <option value="" disabled selected>Select a category</option>
                <option value="Restaurant Review">Restaurant Review</option>
                <option value="Recipe">Recipe</option>
                <option value="Cooking Tip">Cooking Tip</option>
              </select>
            </div>

            <div class="mb-4">
              <div class="content-header">
                <label for="content" class="form-label mb-0">Content</label>
                <button type="button" id="generate-btn" class="ai-generate-btn">
                  Generate Content with AI
                </button>
              </div>
              <textarea id="content" name="content" class="form-control compose-textarea" rows="8" required></textarea>
            </div>

            <div class="mb-4">
              <label for="imageUpload" class="form-label">Upload Image (optional)</label>
              <input type="file" id="imageUpload" class="form-control compose-input" accept="image/*" />
            </div>

            <div class="image-preview-wrapper mb-4">
              <img id="imagePreview" />
            </div>

            <input type="file" name="image" id="croppedImageInput" hidden />

            <div class="publish-row">
              <button type="submit" class="publish-btn">Publish</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
  <!-- Cropper logic -->
  <script src="/js/cropper-handler.js"></script> 
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/ai-content.js"></script>
</body>
</html>

